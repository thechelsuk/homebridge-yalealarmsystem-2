{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "testMatch": ["**/test/**/*.test.ts"],
  "moduleFileExtensions": ["ts", "js", "json"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", {
      "tsconfig": {
        "target": "es2020",
        "module": "commonjs",
        "strict": true,
        "skipLibCheck": true
      }
    }]
  }
}
